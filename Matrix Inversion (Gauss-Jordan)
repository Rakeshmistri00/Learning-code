#include<stdio.h>

int main()
{
    float a[2][4];
    int i,j;

    printf("Enter 2x2 matrix:\n");

    for(i=0;i<2;i++)
    {
        for(j=0;j<2;j++)
        {
            scanf("%f",&a[i][j]);
        }
    }

    // Identity matrix
    a[0][2]=1;
    a[0][3]=0;
    a[1][2]=0;
    a[1][3]=1;

    // Row1 = Row1 / a[0][0]
    float p=a[0][0];
    for(j=0;j<4;j++)
        a[0][j]=a[0][j]/p;

    // Make first column zero
    float q=a[1][0];
    for(j=0;j<4;j++)
        a[1][j]=a[1][j]-q*a[0][j];

    // Row2 = Row2 / a[1][1]
    p=a[1][1];
    for(j=0;j<4;j++)
        a[1][j]=a[1][j]/p;

    // Make second column zero
    q=a[0][1];
    for(j=0;j<4;j++)
        a[0][j]=a[0][j]-q*a[1][j];

    printf("\nInverse Matrix:\n");

    for(i=0;i<2;i++)
    {
        for(j=2;j<4;j++)
        {
            printf("%8.3f ",a[i][j]);
        }
        printf("\n");
    }

    return 0;
}
