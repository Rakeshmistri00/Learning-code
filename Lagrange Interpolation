#include<stdio.h>

int main()
{
    int i,j,n;
    float x[10],y[10],xp,yp=0,p;

    printf("Enter number of points: ");
    scanf("%d",&n);

    printf("Enter x and y values:\n");

    for(i=0;i<n;i++)
    {
        scanf("%f%f",&x[i],&y[i]);
    }

    printf("Enter value of x: ");
    scanf("%f",&xp);

    for(i=0;i<n;i++)
    {
        p=1;

        for(j=0;j<n;j++)
        {
            if(i!=j)
            {
                p=p*(xp-x[j])/(x[i]-x[j]);
            }
        }

        yp=yp+p*y[i];
    }

    printf("Interpolated value = %f",yp);

    return 0;
}
