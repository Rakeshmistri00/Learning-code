#include<stdio.h>
float f(float x){
    return x*x*x-x-2;
}
    float df(float x){
        return 3*x*x-1;
    }
    int main(){
        float x;
        int i;
            printf("Enter the guess :\n");
            scanf("%f",&x);
                for(i=1;i<=10;i++){
                    x=x-f(x)/df(x);
                }
                printf("Root = %f",x);
                return 0;
    }
